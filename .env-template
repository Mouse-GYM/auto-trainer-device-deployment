# Docker Compose project name (prefix)
# Typical value: autotrainer
AUTOTRAINER_COMPOSE_NAME=

# Output location for container logs.
# Typical value: /autotrainer/logs
AUTOTRAINER_LOG_VOLUME=

# Device identifier for notifications and other messaging.
# Typical value: agx001
AUTOTRAINER_DEVICE_ID=

# The AWS SNS topic arn to enable emergency stop/resume notifications.
# Leave blank if not using emergency notifications.
AUTOTRAINER_SNS_TOPIC_ARN=

# The AWS SNS access key id to enable emergency stop/resume notifications.
# Leave blank if not using emergency notifications.
AUTOTRAINER_SNS_KEY_ID=

# The AWS SNS secret key to enable emergency stop/resume notifications.
# Leave blank if not using emergency notifications.
AUTOTRAINER_SNS_KEY=
